.PHONY : src/vtol_mission_node.s

# target to generate assembly for a file
src/vtol_mission_node.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/vtol_mission_node.dir/build.make CMakeFiles/vtol_mission_node.dir/src/vtol_mission_node.cpp.s
.PHONY : src/vtol_mission_node.cpp.s

